rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }
    
    function isVerifiedUser() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isVerifiedUser() && request.auth.token.email == 'smoofikra@gmail.com';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['fullName', 'mobileNumber', 'clientType', 'serviceType', 'appointmentDate', 'appointmentTime', 'createdAt'])
        && data.keys().size() <= 9
        && data.fullName is string
        && data.fullName.size() >= 2
        && data.fullName.size() <= 128
        && data.mobileNumber is string
        && data.mobileNumber.size() >= 9
        && data.mobileNumber.size() <= 20
        && (data.clientType == 'company' || data.clientType == 'individual')
        && data.serviceType is string
        && data.serviceType.size() <= 128
        && data.appointmentDate is string
        && data.appointmentDate.size() == 10
        && data.appointmentTime is string
        && data.appointmentTime.size() <= 5
        && (!data.keys().hasAny(['googleEventId']) || data.googleEventId is string);
    }

    match /bookings/{bookingId} {
      allow get: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
      allow list: if isAdmin();
      
      allow create: if isValidId(bookingId) 
        && isValidBooking(incoming())
        && incoming().createdAt == request.time;
      allow update: if isAdmin()
        && isValidBooking(incoming())
        && incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin();
    }
    
    match /partners/{partnerId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
